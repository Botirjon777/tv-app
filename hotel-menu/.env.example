# MongoDB connection string (e.g. MongoDB Atlas free tier). Must include the
# database name before the query string, e.g. .../hotel_menu?appName=...
MONGODB_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/hotel_menu?appName=Cluster0"

# Auth — set strong values in production. POS signs in per hotel with a connect
# code + password (managed in the admin panel); only the admin password is global.
ADMIN_PASSWORD="admin123"
AUTH_SECRET="change-me-to-a-long-random-string-in-production"

# Telegram bot (from BotFather). Leave TELEGRAM_BOT_TOKEN empty to disable the
# integration. TELEGRAM_WEBHOOK_SECRET is a value you choose and also pass to
# setWebhook; the webhook rejects requests without it.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# Base URL used when generating room QR codes (no trailing slash)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Auto-translation of menu items (en/ru/uz) via the Claude API.
# Without a key, new items are stored untranslated (source text in all languages).
ANTHROPIC_API_KEY=""
# Optional: override the translation model (default claude-opus-4-8).
# TRANSLATION_MODEL="claude-haiku-4-5"

# Fallback USD↔UZS rate used if the live FX lookup fails (approx UZS per 1 USD).
FX_FALLBACK_UZS_PER_USD="12900"
