generator client {
  provider = "prisma-client-js"
}

// MongoDB (e.g. MongoDB Atlas free tier). Atlas clusters are replica sets,
// which Prisma's MongoDB connector requires. DATABASE_URL is the connection
// string (mongodb+srv://…). Schema changes are applied with `prisma db push`
// (MongoDB has no migrations).
datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model Category {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String // source/fallback text (in sourceLang)
  sourceLang String    @default("en")
  nameI18n   String    @default("{}") // JSON: { en, ru, uz }
  sortOrder  Int       @default(0)
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Product {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String // source/fallback text (in sourceLang)
  description String      @default("")
  sourceLang  String      @default("en")
  nameI18n    String      @default("{}") // JSON: { en, ru, uz }
  descI18n    String      @default("{}") // JSON: { en, ru, uz }
  price       Int // integer UZS (so'm) — whole units, no decimals/minor units
  imageUrl    String      @default("")
  available   Boolean     @default(true)
  sortOrder   Int         @default(0)
  categoryId  String      @db.ObjectId
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  recommendations Recommendation[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
}

// "Recommendation of the day" — a product featured on a given weekday.
// Global (shared across hotels, like the menu). dayOfWeek: 0=Sunday … 6=Saturday.
model Recommendation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek Int
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([dayOfWeek, productId])
  @@index([dayOfWeek])
}

model Hotel {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String   @unique
  floors        Int      @default(1)
  roomsPerFloor Int      @default(0)
  active        Boolean  @default(true)

  // Multi-tenant wiring: a short code links the Telegram staff group and is the
  // POS "hotel id"; posPassword gates the per-hotel POS login; telegramChatId is
  // the linked group chat ("" until a manager connects it via the bot).
  connectCode    String  @unique
  posPassword    String  @default("")
  telegramChatId String  @default("")

  // Manager dashboard login + ordering settings.
  managerPassword String  @default("")
  // Telegram forum topics: JSON map of category -> message_thread_id, e.g.
  // { "orders": 12, "taxi": 8 }. Empty when the group has no topics.
  telegramTopics  String  @default("{}")
  serviceFeeType  String  @default("none") // none | percent | fixed
  serviceFeeValue Int     @default(0) // percent (e.g. 10) or fixed UZS amount
  preorderEnabled Boolean @default(false)

  services      HotelService[]

  // Branding & guest-landing content (surfaced on the in-room web page).
  logoUrl        String @default("")
  tripadvisorUrl String @default("")
  googleMapsUrl  String @default("")
  yandexMapsUrl  String @default("")
  wifiName       String @default("")
  wifiPassword   String @default("")
  instagramUrl   String @default("")
  telegramUrl    String @default("")

  rooms         Room[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Room {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  hotelId   String   @db.ObjectId
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  number    String
  name      String   @default("")
  floor     Int      @default(0)
  active    Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Room numbers only need to be unique within a hotel.
  @@unique([hotelId, number])
  @@index([hotelId])
}

model Order {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  roomId    String      @db.ObjectId
  room      Room        @relation(fields: [roomId], references: [id])
  // One of: PENDING | PREPARING | READY | DELIVERED | CANCELLED
  // (validated in app code, see src/lib/orders.ts)
  status    String      @default("PENDING")
  note      String      @default("")
  serviceFee Int        @default(0) // snapshot of the hotel's fee at order time
  total     Int         @default(0) // subtotal + serviceFee, integer UZS (so'm)
  scheduledFor DateTime? // preorder: when the guest wants it (null = ASAP)
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([roomId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @db.ObjectId
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  name      String // snapshot of product name at order time
  price     Int // snapshot of unit price — integer UZS (so'm)
  quantity  Int      @default(1)

  @@index([orderId])
}

// Guest service requests (alarm / reception / taxi / problem) raised from the
// in-room landing. Persisted here so staff can review them; denormalized with
// hotelSlug + roomNumber so no joins are needed for a simple feed.
model ServiceRequest {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  hotelSlug  String
  roomNumber String
  type       String // ALARM | SERVICE | TAXI | RECEPTION | PROBLEM
  note       String   @default("")
  guestName  String   @default("")
  source     String   @default("web")
  status     String   @default("NEW") // NEW | DONE
  // Structured fields: taxi has a destination; taxi & alarm have a scheduled time.
  destination String  @default("")
  scheduledFor DateTime?
  createdAt  DateTime @default(now())

  @@index([hotelSlug, roomNumber])
  @@index([createdAt])
}

// Manager-defined services shown on the in-room landing (transfer to airport,
// pool, conference hall, …). Per hotel, translatable like menu items.
model HotelService {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  hotelId     String   @db.ObjectId
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String // source/fallback text
  sourceLang  String   @default("en")
  nameI18n    String   @default("{}") // JSON: { en, ru, uz }
  description String   @default("")
  descI18n    String   @default("{}")
  icon        String   @default("") // optional icon key
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([hotelId])
}
