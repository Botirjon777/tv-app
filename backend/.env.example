# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hoteltv:hoteltv@localhost:5432/hoteltv"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Minimum 32 characters (64+ recommended). Generate with: npm run gen:secrets
JWT_SECRET="dev-only-change-me-0000000000000000000000000000000000000000000000"

# Single admin account. Required in production; optional in dev (admin API
# returns 503 until set). Generate the hash with:
#   npm run hash:password -- 'your-password'
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH=""

# Shared secret protecting the internal /menu/data Prisma bridge used by the
# hotel-menu app. REQUIRED in production; the route is disabled if unset.
INTERNAL_API_KEY=""

# ── CORS ──────────────────────────────────────────────────────────────────────
# "*" is allowed in dev only. In production use a comma-separated origin list.
CORS_ORIGIN="*"

# ── Exely PMS ─────────────────────────────────────────────────────────────────
# Required in production (webhook signature verification).
EXELY_WEBHOOK_SECRET="your-exely-shared-secret"

# ── OpenWeatherMap (optional) ─────────────────────────────────────────────────
OPENWEATHER_API_KEY=""

# ── Telegram notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── Media storage (local disk / mounted volume) ───────────────────────────────
MEDIA_DIR="uploads"
# Public origin of this backend, used to build absolute media URLs. Leave empty
# to return relative /media/<key> URLs.
PUBLIC_BASE_URL=""
MAX_UPLOAD_MB=50

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW="1 minute"
