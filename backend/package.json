{
  "name": "hotel-tv-backend",
  "version": "1.0.0",
  "description": "Hotel TV Platform — Fastify backend with Prisma, Redis, WebSocket",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "db:deploy": "prisma migrate deploy",
    "hash:password": "ts-node scripts/hash-password.ts",
    "gen:secrets": "node -e \"const c=require('crypto');console.log('JWT_SECRET='+c.randomBytes(48).toString('hex'));console.log('INTERNAL_API_KEY='+c.randomBytes(24).toString('hex'));console.log('EXELY_WEBHOOK_SECRET='+c.randomBytes(24).toString('hex'));\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "prisma": "^5.16.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
