# ==============================================================================
# Production environment for docker-compose.prod.yml (VPS deployment).
#
#   cp .env.production.example .env
#   npm run gen:secrets           # prints strong JWT_SECRET / INTERNAL_API_KEY / EXELY_WEBHOOK_SECRET
#   npm run hash:password -- 'your-admin-password'   # prints ADMIN_PASSWORD_HASH
#
# Then paste the generated values below. NEVER commit the filled-in .env.
# ==============================================================================

# ── Public hostname & TLS (Caddy) ─────────────────────────────────────────────
# DNS A/AAAA record for this domain must point at the VPS. Caddy auto-issues a
# Let's Encrypt cert for it.
APP_DOMAIN="api.yourhotel.com"
PUBLIC_BASE_URL="https://api.yourhotel.com"

# Comma-separated allowlist of origins permitted to call the API (admin panel,
# web menu, …). Must NOT be "*" in production.
CORS_ORIGIN="https://admin.yourhotel.com,https://menu.yourhotel.com"

# ── Database (Postgres container) ─────────────────────────────────────────────
POSTGRES_DB="hoteltv"
POSTGRES_USER="hoteltv"
# Use a long random password. e.g. `openssl rand -hex 24`
POSTGRES_PASSWORD="CHANGE_ME_long_random_db_password"

# ── Auth secrets (generate with `npm run gen:secrets`) ────────────────────────
JWT_SECRET="CHANGE_ME_at_least_32_chars_use_gen_secrets"
INTERNAL_API_KEY="CHANGE_ME_protects_the_menu_data_bridge"

# ── Admin login (single admin via env) ────────────────────────────────────────
ADMIN_EMAIL="admin@yourhotel.com"
# Generate with: npm run hash:password -- 'your-admin-password'
ADMIN_PASSWORD_HASH="$2a$12$CHANGE_ME_bcrypt_hash"

# ── Exely PMS webhook (required in production) ────────────────────────────────
EXELY_WEBHOOK_SECRET="CHANGE_ME_shared_secret_from_exely"

# ── Optional integrations (leave blank to disable) ────────────────────────────
OPENWEATHER_API_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── Tuning ────────────────────────────────────────────────────────────────────
# Max requests per IP per minute (global). Login/register have their own limits.
RATE_LIMIT_MAX="300"
